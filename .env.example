# ---------------------------------------------------------------------------
# Coin Hub — environment template. Copy to `.env` and fill in real values.
# Never commit the real `.env` (it is gitignored).
# ---------------------------------------------------------------------------

# --- Database (PostgreSQL) ---
DB_HOST=db
DB_PORT=5432
EXTERNAL_DB_PORT=5450          # host port mapped to Postgres (for local tooling)
DB_NAME=coin_hub
DB_USER=coin_hub
DB_PASSWORD=change_me
DATABASE_URL=postgresql://coin_hub:change_me@db:5432/coin_hub

# --- API (Go backend) ---
API_PORT=5020                  # nginx (coin.bobagi.space) proxies to this port
APP_BASE_URL=https://coin.bobagi.space   # also the allowed Origin for the same-origin (CSRF) guard
SESSION_LIFETIME_HOURS=168     # session cookie lifetime (default 7 days)
MAX_ORDER_QUOTE_AMOUNT=100000  # server-side ceiling on a single buy's quote amount (0 = no cap)
ACCESS_LOG_RETENTION_DAYS=180  # auto-delete sign-in log rows (IP/UA/location PII) older than N days; 0 = keep until account deletion (LGPD data-minimization)

# --- Security (Phase 1: multi-user) ---
# 32+ char random string used to sign session/JWT tokens.
APP_SECRET_KEY=change_me_to_a_long_random_string
# Base64-encoded 32-byte key used to encrypt each user's Binance secret at rest (AES-256-GCM).
# Generate with: openssl rand -base64 32
CREDENTIALS_ENCRYPTION_KEY=

# --- Google sign-in (OAuth 2.0) — optional ---
# In Google Cloud Console → APIs & Services → Credentials, create an "OAuth client ID" of type
# "Web application". Add this EXACT authorized redirect URI:
#     https://coin.bobagi.space/auth/google/callback
# Then paste the client id/secret below. Leave blank to disable Google sign-in (the button is
# hidden automatically and the email/password flow keeps working).
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URL=https://coin.bobagi.space/auth/google/callback

# --- SMTP (price/email alerts; app-level sender, alerts go to each user's recipient) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_address@gmail.com
SMTP_PASSWORD=your_gmail_app_password
SMTP_FROM=your_address@gmail.com

# --- Binance defaults ---
# Per-user API keys are stored encrypted in the DB. New users default to TESTNET;
# enabling live trading is an explicit, per-user opt-in.
BINANCE_DEFAULT_ENVIRONMENT=TESTNET
BINANCE_TESTNET_BASE_URL=https://testnet.binance.vision
BINANCE_PRODUCTION_BASE_URL=https://api.binance.com
# Optional: route ALL Binance REST + WebSocket traffic through this proxy, so a worker instance egresses
# from a specific IP. The Binance weight limit is per-IP, so parallel worker shards only help when each
# uses a DIFFERENT proxy/IP. Leave blank for a direct connection. (May embed credentials — never logged.)
# BINANCE_HTTP_PROXY=http://user:pass@proxy-host:8080

# --- Worker parallelism (automation worker) — optional ---
# The trading worker is a singleton PER SHARD via a Postgres advisory lock. To run workers in parallel,
# set WORKER_SHARD_COUNT=N and deploy N instances, each with a distinct WORKER_SHARD_INDEX (0..N-1); each
# processes users where (id % N == index). Default count=1 = one worker handling everyone (unchanged).
# Pair distinct shards with distinct BINANCE_HTTP_PROXY values (per-IP limit). Premature below real volume.
WORKER_SHARD_COUNT=1
WORKER_SHARD_INDEX=0

# --- Trading defaults (used to seed new users' settings; overridable per user) ---
DEFAULT_TRADE_SYMBOL=BTCUSDT
DEFAULT_SELL_THRESHOLD_PCT=1.0
DEFAULT_PURCHASE_LIMIT_QUOTE=100.0
DEFAULT_POLL_INTERVAL_SECONDS=60
DEFAULT_DAILY_SPEND=10
DEFAULT_DIP_HOUR_UTC=4

# --- Scraper (investidor10 portfolio service) ---
SCRAPER_BASE_URL=http://scraper:5000
